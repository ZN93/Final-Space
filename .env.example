# ===============================
# Final Space - Docker environment
# ===============================

# PostgreSQL
POSTGRES_DB=finalspace
POSTGRES_USER=finalspace
POSTGRES_PASSWORD=finalspace

# MongoDB
MONGO_INITDB_ROOT_USERNAME=finalspace
MONGO_INITDB_ROOT_PASSWORD=finalspace
MONGO_DATABASE=finalspace

# Backend
BACKEND_PORT=8080
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false

# JWT
JWT_SECRET=finalspace-secret-key-finalspace-secret-key-change-me
JWT_EXPIRATION=86400000

# Frontend
FRONTEND_PORT=80

# CORS
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:4200,http://localhost:8080